# Copy this file to .env and fill in your values.
# Never commit .env to git.

# JWT Secret (change in production)
SECRET_KEY=careskill-dev-secret-CHANGE-IN-PRODUCTION

# Google Calendar / Meet integration
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Hostinger SFTP — remote storage for images/videos/documents.
# Postgres stores only metadata + public URL, never file bytes.
HOSTINGER_HOST=your-domain.com
HOSTINGER_PORT=65002
HOSTINGER_USERNAME=your-sftp-username
HOSTINGER_PASSWORD=your-sftp-password
# Absolute remote path uploads are written under. On Hostinger's shared hosting,
# the SFTP account home is /home/<username>, and each domain's docroot lives at
# /home/<username>/domains/<your-domain>/public_html — NOT /public_html directly.
HOSTINGER_UPLOAD_ROOT=/home/your-sftp-username/domains/your-domain.com/public_html/uploads
# Public base URL that maps to HOSTINGER_UPLOAD_ROOT
HOSTINGER_PUBLIC_BASE_URL=https://your-domain.com/uploads
